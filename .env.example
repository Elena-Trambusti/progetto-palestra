# --- Modalità gateway (consigliata con `npm run stack`) ---
# Con `REACT_APP_GATEWAY_MODE=proxy` il browser chiama `/api` e `/ws` sullo stesso host
# (proxy CRA → server su porta 4000). `npm run stack` imposta questa variabile automaticamente.
REACT_APP_GATEWAY_MODE=

# Se preferisci URL assoluti invece del proxy, imposta l'origine del backend:
# REACT_APP_SENSOR_API_URL=http://localhost:4000

# WebSocket esplicito (opzionale; in proxy mode si usa /ws automaticamente)
# REACT_APP_SENSOR_WS_URL=

# Se il backend richiede autenticazione o API key:
# REACT_APP_SENSOR_API_KEY=

# Intervallo polling REST in millisecondi (default 3000)
REACT_APP_POLL_INTERVAL_MS=3000

# Riga sotto il titolo (es. nome commerciale + città)
REACT_APP_FACILITY_LINE=Hub principale · Livorno

# Target del proxy (solo sviluppo, vedi src/setupProxy.js)
# REACT_APP_PROXY_TARGET=http://localhost:4000
