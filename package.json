{
  "name": "palestra-dashboard",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "chart.js": "^4.4.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "http-proxy-middleware": "^2.0.9",
    "patch-package": "^8.0.1",
    "start-server-and-test": "^2.1.5",
    "yaml": "^2.8.3"
  },
  "scripts": {
    "postinstall": "patch-package || true",
    "telegram:test": "node scripts/telegram-test-send.js",
    "start": "node server/index.js",
    "start:frontend": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "cross-env CI=true react-scripts test --watch=false --passWithNoTests",
    "lint:frontend": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "lint": "npm run lint:frontend",
    "test:all": "npm run test:ci && npm --prefix server test",
    "verify:ci": "npm run lint && npm run test:all && npm run build",
    "eject": "react-scripts eject",
    "server": "npm --prefix server start",
    "stack": "start-server-and-test \"npm run server\" http://127.0.0.1:4000/api/zones \"cross-env REACT_APP_GATEWAY_MODE=proxy npm run start:frontend\"",
    "sim:lora": "node server/tools/loraGatewaySimulator.js",
    "demo:reset": "node server/tools/resetDemoData.js",
    "demo": "start-server-and-test \"npm run server\" http://127.0.0.1:4000/api/zones \"concurrently -k -n FRONTEND,SIM \\\"cross-env REACT_APP_GATEWAY_MODE=proxy npm run start:frontend\\\" \\\"cross-env SIM_API_BASE=http://127.0.0.1:4000 npm run sim:lora\\\"\"",
    "demo:clean": "npm run demo:reset && npm run demo"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
