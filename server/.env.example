PORT=4000

# PostgreSQL: obbligatorio per POST /api/ingest (webhook The Things Network) e CRUD sensori.
# Esempio: postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Chiave macchina-macchina (header x-api-key). Opzionale.
API_KEY=

# Origine browser (CRA). Lista separata da virgola se serve.
CORS_ORIGIN=http://localhost:3000

# Autenticazione dashboard (cookie + Bearer)
# In produzione deve essere true.
REQUIRE_AUTH=true
# Obbligatoria (non vuota) se REQUIRE_AUTH=true
AUTH_PASSWORD=
# Lunghezza minima password dashboard in produzione
AUTH_MIN_PASSWORD_LEN=12

# Cartella dati persistenti (serie storiche JSONL)
DATA_DIR=

# Webhook POST JSON quando il livello acqua scende sotto il 20% (cooldown 5 min default)
NOTIFY_WEBHOOK_URL=
NOTIFY_COOLDOWN_MS=300000
# Cooldown separato per allerta “calo rapido” (tipo water_rapid_drop)
NOTIFY_WATER_RAPID_COOLDOWN_MS=600000

# Stima tempo a soglia 20% da storico (ms di lookback regression)
WATER_ETA_LOOKBACK_MS=2700000
# Finestra e soglia per calo rapido (Δ% tra prima lettura nella finestra e oggi)
WATER_RAPID_WINDOW_MS=600000
WATER_RAPID_DROP_PCT=12

# Segreto per POST /api/ingest e /api/ingest/reading. Header: x-ingest-secret
# In produzione obbligatorio (stesso valore sul webhook TTN).
INGEST_SECRET=

# Rate limit ingest (per IP): max richieste per finestra temporale (default prod 120, dev 240 / min).
#INGEST_RATE_LIMIT_MAX=120
#INGEST_RATE_LIMIT_WINDOW_MS=60000

# Notifiche allarmi soglia (ingest TTN). Opzionali: senza di esse l'app non crasha.
# Prova locale: npm run telegram:test (dalla root del repo, con .env valorizzato)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Abilita trust proxy dietro reverse proxy/load balancer.
TRUST_PROXY=false

# Se true, non genera più dati random: solo letture da ingest (e storico su file)
DISABLE_AUTO_TICK=false

# Soglie allarmi ambientali (webhook type env_threshold)
ALARM_TEMP_HIGH_C=32
ALARM_TEMP_LOW_C=17
ALARM_HUMIDITY_HIGH_PCT=72
ALARM_HUMIDITY_LOW_PCT=28
ALARM_CO2_HIGH_PPM=1000
ALARM_VOC_HIGH=350
NOTIFY_ENV_COOLDOWN_MS=300000

# Alert operativi (webhook type ops_alert)
# Finestra analisi e frequenza controllo
OPS_ALERT_WINDOW_MS=300000
OPS_ALERT_CHECK_EVERY_MS=60000
# Trigger 5xx: percentuale minima su almeno OPS_ALERT_MIN_REQUESTS richieste/finestra
OPS_ALERT_5XX_RATE_PCT=1
OPS_ALERT_MIN_REQUESTS=30
# Trigger spike di rifiuti/finestra
OPS_ALERT_WS_REJECTS_DELTA=5
OPS_ALERT_INGEST_REJECTS_DELTA=5
# Cooldown tra alert operativi con stessa chiave
NOTIFY_OPS_COOLDOWN_MS=300000
