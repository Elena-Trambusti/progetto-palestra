PORT=4000

# Chiave macchina-macchina (header x-api-key). Opzionale.
API_KEY=

# Origine browser (CRA). Lista separata da virgola se serve.
CORS_ORIGIN=http://localhost:3000

# Autenticazione dashboard (cookie + Bearer)
# In produzione deve essere true.
REQUIRE_AUTH=true
# Obbligatoria (non vuota) se REQUIRE_AUTH=true
AUTH_PASSWORD=
# Lunghezza minima password dashboard in produzione
AUTH_MIN_PASSWORD_LEN=12

# Cartella dati persistenti (serie storiche JSONL)
DATA_DIR=

# Webhook POST JSON quando il livello acqua scende sotto il 20% (cooldown 5 min default)
NOTIFY_WEBHOOK_URL=
NOTIFY_COOLDOWN_MS=300000
# Cooldown separato per allerta “calo rapido” (tipo water_rapid_drop)
NOTIFY_WATER_RAPID_COOLDOWN_MS=600000

# Stima tempo a soglia 20% da storico (ms di lookback regression)
WATER_ETA_LOOKBACK_MS=2700000
# Finestra e soglia per calo rapido (Δ% tra prima lettura nella finestra e oggi)
WATER_RAPID_WINDOW_MS=600000
WATER_RAPID_DROP_PCT=12

# Segreto per POST /api/ingest/reading (Arduino / ESP). Header: x-ingest-secret
# In produzione obbligatorio.
INGEST_SECRET=

# Abilita trust proxy dietro reverse proxy/load balancer.
TRUST_PROXY=false

# Se true, non genera più dati random: solo letture da ingest (e storico su file)
DISABLE_AUTO_TICK=false

# Soglie allarmi ambientali (webhook type env_threshold)
ALARM_TEMP_HIGH_C=32
ALARM_TEMP_LOW_C=17
ALARM_HUMIDITY_HIGH_PCT=72
ALARM_HUMIDITY_LOW_PCT=28
ALARM_CO2_HIGH_PPM=1000
ALARM_VOC_HIGH=350
NOTIFY_ENV_COOLDOWN_MS=300000
